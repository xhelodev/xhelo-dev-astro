---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import profilePic from "../assets/yo.jpeg";
---

<Layout>
  <!-- Hero -->
  <section class="relative pt-10 pb-4">
    <div class="hero-glow"></div>
    <Image
      src={profilePic}
      alt="Marcelo Aguirre"
      width="96"
      height="96"
      fetchpriority="high"
      class="rounded-2xl object-cover w-20 h-20 mb-5 shadow-sm relative"
    />
    <h1 class="text-3xl font-bold tracking-tight mb-1">Marcelo Aguirre</h1>
    <p class="text-[var(--fg-muted)] text-base leading-relaxed">
      <span x-show="language === 'es'">Senior Fullstack Developer · TypeScript Specialist · Backend-Oriented</span>
      <span x-show="language === 'en'">Senior Fullstack Developer · TypeScript Specialist · Backend-Oriented</span>
    </p>

    <!-- Socials -->
    <div class="flex items-center gap-4 mt-4">
      <a href="https://www.linkedin.com/in/xhelodev" target="_blank" rel="noopener" aria-label="LinkedIn" class="text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="https://github.com/xhelodev" target="_blank" rel="noopener" aria-label="GitHub" class="text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      </a>
      <a href="https://t.me/xhelodev" target="_blank" rel="noopener" aria-label="Telegram" class="text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </a>
      <a href="mailto:contact@xhelo.dev" aria-label="Email" class="text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      </a>
    </div>
  </section>

  <hr class="divider" />

  <!-- Sobre mí -->
  <section>
    <h2 class="text-xl font-semibold mb-4">
      <span x-show="language === 'es'">Sobre mí</span>
      <span x-show="language === 'en'">About me</span>
    </h2>
    <div class="space-y-4 text-[var(--fg)]">
      <p x-show="language === 'es'">
        Desarrollador especializado en arquitecturas robustas de extremo a extremo, con foco en <strong>rendimiento</strong>, <strong>escalabilidad</strong> y <strong>experiencia de usuario</strong>. Apasionado por el ecosistema <strong>Web3</strong>, <strong>blockchain</strong> e <strong>Inteligencia Artificial</strong>.
      </p>
      <p x-show="language === 'es'">
        Con sólida experiencia en infraestructura <strong>Linux</strong> y servidores, construyo soluciones que combinan fiabilidad técnica con innovación.
      </p>

      <p x-show="language === 'en'">
        Developer specialized in robust end-to-end architectures, with a focus on <strong>performance</strong>, <strong>scalability</strong> and <strong>user experience</strong>. Passionate about the <strong>Web3</strong>, <strong>blockchain</strong> and <strong>Artificial Intelligence</strong> ecosystem.
      </p>
      <p x-show="language === 'en'">
        With solid experience in <strong>Linux</strong> infrastructure and servers, I build solutions that combine technical reliability with innovation.
      </p>
    </div>
  </section>

  <hr class="divider" />

  <!-- Tech Stack -->
  <section>
    <h2 class="text-xl font-semibold mb-4">
      <span x-show="language === 'es'">Tech Stack</span>
      <span x-show="language === 'en'">Tech Stack</span>
    </h2>
    <div class="space-y-4">
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <span class="text-sm font-medium text-[var(--fg-muted)] w-24 shrink-0">
          <span x-show="language === 'es'">Core</span>
          <span x-show="language === 'en'">Core</span>
        </span>
        <span class="badge">TypeScript</span>
        <span class="badge">Node.js</span>
        <span class="badge">JavaScript</span>
      </div>
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <span class="text-sm font-medium text-[var(--fg-muted)] w-24 shrink-0">
          <span x-show="language === 'es'">Backend</span>
          <span x-show="language === 'en'">Backend</span>
        </span>
        <span class="badge badge-backend">NestJS</span>
        <span class="badge badge-backend">Laravel</span>
        <span class="badge badge-backend">REST APIs</span>
        <span class="badge badge-backend">GraphQL</span>
      </div>
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <span class="text-sm font-medium text-[var(--fg-muted)] w-24 shrink-0">
          <span x-show="language === 'es'">Frontend</span>
          <span x-show="language === 'en'">Frontend</span>
        </span>
        <span class="badge badge-frontend">React</span>
        <span class="badge badge-frontend">Next.js</span>
        <span class="badge badge-frontend">Tailwind CSS</span>
      </div>
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <span class="text-sm font-medium text-[var(--fg-muted)] w-24 shrink-0">
          <span x-show="language === 'es'">Web3</span>
          <span x-show="language === 'en'">Web3</span>
        </span>
        <span class="badge badge-web3">Solidity</span>
        <span class="badge badge-web3">ethers.js</span>
        <span class="badge badge-web3">viem</span>
        <span class="badge badge-web3">Smart Contracts</span>
        <span class="badge badge-web3">DeFi Protocols</span>
      </div>
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <span class="text-sm font-medium text-[var(--fg-muted)] w-24 shrink-0">
          <span x-show="language === 'es'">Infra</span>
          <span x-show="language === 'en'">Infra</span>
        </span>
        <span class="badge badge-infra">Docker</span>
        <span class="badge badge-infra">Linux</span>
        <span class="badge badge-infra">Bash</span>
        <span class="badge badge-infra">CI/CD</span>
        <span class="badge badge-infra">Server Management</span>
      </div>
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <span class="text-sm font-medium text-[var(--fg-muted)] w-24 shrink-0">
          <span x-show="language === 'es'">Databases</span>
          <span x-show="language === 'en'">Databases</span>
        </span>
        <span class="badge badge-db">PostgreSQL</span>
        <span class="badge badge-db">MariaDB</span>
        <span class="badge badge-db">SQLite</span>
        <span class="badge badge-db">Redis</span>
      </div>
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <span class="text-sm font-medium text-[var(--fg-muted)] w-24 shrink-0">
          <span x-show="language === 'es'">Emerging</span>
          <span x-show="language === 'en'">Emerging</span>
        </span>
        <span class="badge badge-emerging">AI Integration</span>
        <span class="badge badge-emerging">Blockchain Bots</span>
        <span class="badge badge-emerging">Trading Systems</span>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Áreas de Enfoque -->
  <section>
    <h2 class="text-xl font-semibold mb-4">
      <span x-show="language === 'es'">Áreas de Enfoque</span>
      <span x-show="language === 'en'">Focus Areas</span>
    </h2>
    <ul class="notion-list">
      <li x-show="language === 'es'">
        <strong>Arquitecturas Backend Escalables</strong> — Microservicios, event-driven, sistemas distribuidos
      </li>
      <li x-show="language === 'es'">
        <strong>Web3 & Blockchain</strong> — Integración de wallets, protocolos DeFi, bots de trading automatizados
      </li>
      <li x-show="language === 'es'">
        <strong>Infraestructura Linux</strong> — Optimización de servidores, scripting, despliegues en producción
      </li>
      <li x-show="language === 'es'">
        <strong>Integración de IA</strong> — Modelos LLM, automatización inteligente, pipelines de datos
      </li>

      <li x-show="language === 'en'">
        <strong>Scalable Backend Architectures</strong> — Microservices, event-driven, distributed systems
      </li>
      <li x-show="language === 'en'">
        <strong>Web3 & Blockchain</strong> — Wallet integration, DeFi protocols, automated trading bots
      </li>
      <li x-show="language === 'en'">
        <strong>Linux Infrastructure</strong> — Server optimization, scripting, production deployments
      </li>
      <li x-show="language === 'en'">
        <strong>AI Integration</strong> — LLM models, intelligent automation, data pipelines
      </li>
    </ul>
  </section>

  <hr class="divider" />

  <!-- Colaboraciones -->
  <section>
    <div class="callout">
      <div class="flex items-start gap-3">
        <span class="text-lg shrink-0">💡</span>
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-1">
            <span class="status-dot"></span>
            <h3 class="font-semibold text-[var(--fg)]">
              <span x-show="language === 'es'">Colaboraciones</span>
              <span x-show="language === 'en'">Collaborations</span>
            </h3>
          </div>
          <p class="text-[var(--fg-muted)] text-sm leading-relaxed">
            <span x-show="language === 'es'">Disponible para proyectos de alto impacto, consultoría técnica y colaboraciones en ecosistemas <strong>Web3</strong> y <strong>AI</strong>.</span>
            <span x-show="language === 'en'">Available for high-impact projects, technical consulting and collaborations in <strong>Web3</strong> and <strong>AI</strong> ecosystems.</span>
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
