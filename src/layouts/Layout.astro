---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { ClientRouter } from "astro:transitions";
import "@fontsource/inter";
---

<html
  lang="es"
  x-data="{ 
    theme: localStorage.getItem('theme') || 'dark',
    language: localStorage.getItem('language') || 'es'
  }"
  x-init="
    $watch('theme', value => {
      localStorage.setItem('theme', value);
      document.documentElement.classList.toggle('dark-mode', value === 'dark');
    });
    $watch('language', value => {
      localStorage.setItem('language', value);
      document.documentElement.lang = value;
    });
    document.documentElement.classList.toggle('dark-mode', theme === 'dark');
    document.documentElement.lang = language;
  "
  :class="{ 'dark-mode': theme === 'dark' }"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Marcelo Aguirre — Full Stack Developer</title>
    <meta name="description" content="Senior Fullstack Developer · TypeScript Specialist · Backend-Oriented. Specialized in robust end-to-end architectures, Web3, and AI." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme') || 'dark';
        var lang = localStorage.getItem('language') || 'es';
        if (theme === 'dark') document.documentElement.classList.add('dark-mode');
        document.documentElement.lang = lang;
      })();
    </script>
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <ClientRouter />
  </head>

  <body class="min-h-screen antialiased">
    <!-- Top bar: language + theme -->
    <div class="max-w-2xl mx-auto px-6 pt-6 flex items-center justify-end gap-4 text-sm">
      <div class="flex items-center gap-1">
        <button
          @click="language = 'es'"
          class="px-1.5 py-0.5 rounded transition-colors"
          :class="language === 'es' ? 'font-semibold text-[var(--fg)]' : 'text-[var(--fg-faint)] hover:text-[var(--fg-muted)]'"
        >ES</button>
        <span class="text-[var(--border-strong)]">/</span>
        <button
          @click="language = 'en'"
          class="px-1.5 py-0.5 rounded transition-colors"
          :class="language === 'en' ? 'font-semibold text-[var(--fg)]' : 'text-[var(--fg-faint)] hover:text-[var(--fg-muted)]'"
        >EN</button>
      </div>

      <button
        @click="theme = theme === 'dark' ? 'light' : 'dark'"
        class="p-1.5 rounded-md hover:bg-[var(--badge-bg)] text-[var(--fg-muted)] transition-colors"
        aria-label="Toggle theme"
      >
        <svg x-cloak x-show="theme === 'dark'" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg x-cloak x-show="theme === 'light'" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>

    <main class="max-w-2xl mx-auto px-6 pb-20">
      <slot />
    </main>

    <footer class="max-w-2xl mx-auto px-6 pb-10 text-center">
      <p class="text-xs text-[var(--fg-faint)]">
        <span x-show="language === 'es'">Built with passion for code, cryptography, and decentralized systems.</span>
        <span x-show="language === 'en'">Built with passion for code, cryptography, and decentralized systems.</span>
      </p>
    </footer>

    <Analytics />
    <SpeedInsights />
  </body>
</html>
